{% comment %}Product Recommendations - Works on both product pages and home page{% endcomment %}

{%- if template contains 'product' -%}
  {%- liquid
    assign current_product = product
    assign target_collection = ''
    assign max_products = section.settings.products_to_show | default: 10
    assign per_row = section.settings.products_per_row | default: 5

    # Calculate grid width based on products per row
    if per_row == 3
      assign grid_item_width = 'small--one-half medium-up--one-third'
    elsif per_row == 4
      assign grid_item_width = 'small--one-half medium-up--one-quarter'
    elsif per_row == 5
      assign grid_item_width = 'small--one-half medium-up--one-fifth'
    elsif per_row == 6
      assign grid_item_width = 'small--one-half medium-up--one-sixth'
    endif

    assign mens_broad_collection = section.settings.mens_broad_collection | default: 'mens-clothes'
    assign womens_broad_collection = section.settings.womens_broad_collection | default: 'womens-clothes'
    
    assign smallest_count = 9999
    for collection in current_product.collections
      assign collection_handle = collection.handle
      unless collection_handle == mens_broad_collection or collection_handle == womens_broad_collection
        if collection.products_count < smallest_count and collection.products_count > 1
          assign target_collection = collection
          assign smallest_count = collection.products_count
        endif
      endunless
    endfor
    
    unless target_collection
      for collection in current_product.collections
        assign collection_handle = collection.handle
        unless collection_handle == mens_broad_collection or collection_handle == womens_broad_collection
          assign target_collection = collection
          break
        endunless
      endfor
    endunless
    
    unless target_collection
      assign target_collection = current_product.collections.first
    endunless
    
    assign broader_collection = ''
    for collection in current_product.collections
      if collection.products_count > target_collection.products_count
        assign broader_collection = collection
        break
      endif
    endfor
  -%}

  {%- if target_collection and target_collection.products_count > 1 -%}
    <style>
      .grid-product__image-mask {
        position: relative;
        display: block;
        width: 100%;
        background: #f5f5f5;
        overflow: hidden;
      }
      .grid__image-ratio--portrait {
        position: relative;
        width: 100%;
        height: 0;
        padding-bottom: 150%;
        overflow: hidden;
      }
      .grid__image-ratio--portrait image-element,
      .grid__image-ratio--portrait img {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        height: 100% !important;
        display: block !important;
        opacity: 1 !important;
        visibility: visible !important;
      }
      .grid__image-ratio--portrait img {
        object-fit: cover;
        object-position: center;
      }
      .grid-product__secondary-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 2;
      }
      .grid-product__secondary-image image-element,
      .grid-product__secondary-image img {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        height: 100% !important;
        display: block !important;
        object-fit: cover;
        object-position: center;
      }
      .grid-product__link:hover .grid-product__secondary-image {
        opacity: 1 !important;
      }
      image-element {
        display: block !important;
        width: 100% !important;
        height: 100% !important;
        opacity: 1 !important;
        visibility: visible !important;
      }
      [data-aos="image-fade-in"],
      [data-aos="image-fade-in"] img {
        opacity: 1 !important;
        visibility: visible !important;
        transform: none !important;
      }
    </style>

    <div id="RecommendationsSection-product" data-section-type="product-recommendations">
      <div class="page-width">
        <div class="section-header">
          <h2 class="section-header__title">{{ section.settings.heading | default: "You might also like" }}</h2>
        </div>
      </div>
      <div class="page-width page-width--flush-small">
        <div class="grid-overflow-wrapper">
          <div class="grid grid--uniform" data-aos="overflow__animation">
            {%- assign shown_count = 0 -%}
            {%- assign shown_ids = '' -%}
            
            {%- for product_item in target_collection.products limit: 30 -%}
              {%- unless product_item.id == current_product.id -%}
                {%- if shown_count < max_products -%}
                  <div class="grid__item grid-product {{ grid_item_width }}" data-aos="row-of-{{ per_row }}">
                    <div class="grid-product__content">
                      <a href="{{ product_item.url | within: target_collection }}" class="grid-product__link">
                        <div class="grid-product__image-mask">
                          <div class="grid__image-ratio grid__image-ratio--portrait">
                            <image-element data-aos="image-fade-in" data-aos-offset="150">
                              <img src="{{ product_item.featured_image | image_url: width: 1080 }}" 
                                   alt="{{ product_item.featured_image.alt | escape }}"
                                   srcset="{{ product_item.featured_image | image_url: width: 360 }} 360w,
                                           {{ product_item.featured_image | image_url: width: 540 }} 540w,
                                           {{ product_item.featured_image | image_url: width: 720 }} 720w,
                                           {{ product_item.featured_image | image_url: width: 900 }} 900w,
                                           {{ product_item.featured_image | image_url: width: 1080 }} 1080w"
                                   width="1080" 
                                   height="{{ 1080 | divided_by: product_item.featured_image.aspect_ratio | round }}"
                                   loading="lazy" 
                                   sizes="(min-width: 769px) 20vw, 50vw">
                            </image-element>
                          </div>
                          {% if product_item.images[1] %}
                            <div class="grid-product__secondary-image small--hide">
                              <image-element data-aos="image-fade-in" data-aos-offset="150">
                                <img src="{{ product_item.images[1] | image_url: width: 1000 }}" 
                                     alt="{{ product_item.images[1].alt | escape }}"
                                     srcset="{{ product_item.images[1] | image_url: width: 360 }} 360w,
                                             {{ product_item.images[1] | image_url: width: 540 }} 540w,
                                             {{ product_item.images[1] | image_url: width: 720 }} 720w,
                                             {{ product_item.images[1] | image_url: width: 1000 }} 1000w"
                                     width="1000" 
                                     loading="lazy" 
                                     sizes="(min-width: 769px) 20vw, 50vw">
                              </image-element>
                            </div>
                          {% endif %}
                        </div>
                        <div class="grid-product__meta">
                          <div class="grid-product__title">{{ product_item.title }}</div>
                          <div class="grid-product__price">
                            {% if product_item.compare_at_price > product_item.price %}
                              <span class="grid-product__price--original">{{ product_item.compare_at_price | money }}</span>
                              <span class="sale-price">{{ product_item.price | money }}</span>
                            {% else %}
                              {{ product_item.price | money }}
                            {% endif %}
                          </div>
                        </div>
                      </a>
                    </div>
                  </div>
                  {%- assign shown_count = shown_count | plus: 1 -%}
                  {%- assign shown_ids = shown_ids | append: product_item.id | append: ',' -%}
                {%- endif -%}
              {%- endunless -%}
            {%- endfor -%}
            
            {%- if shown_count < max_products and broader_collection != '' -%}
              {%- for product_item in broader_collection.products limit: 30 -%}
                {%- unless product_item.id == current_product.id -%}
                  {%- unless shown_ids contains product_item.id -%}
                    {%- if shown_count < max_products -%}
                      <div class="grid__item grid-product {{ grid_item_width }}" data-aos="row-of-{{ per_row }}">
                        <div class="grid-product__content">
                          <a href="{{ product_item.url | within: broader_collection }}" class="grid-product__link">
                            <div class="grid-product__image-mask">
                              <div class="grid__image-ratio grid__image-ratio--portrait">
                                <image-element data-aos="image-fade-in" data-aos-offset="150">
                                  <img src="{{ product_item.featured_image | image_url: width: 1080 }}" 
                                       alt="{{ product_item.featured_image.alt | escape }}"
                                       srcset="{{ product_item.featured_image | image_url: width: 360 }} 360w,
                                               {{ product_item.featured_image | image_url: width: 540 }} 540w,
                                               {{ product_item.featured_image | image_url: width: 720 }} 720w,
                                               {{ product_item.featured_image | image_url: width: 900 }} 900w,
                                               {{ product_item.featured_image | image_url: width: 1080 }} 1080w"
                                       width="1080" 
                                       height="{{ 1080 | divided_by: product_item.featured_image.aspect_ratio | round }}"
                                       loading="lazy" 
                                       sizes="(min-width: 769px) 20vw, 50vw">
                                </image-element>
                              </div>
                              {% if product_item.images[1] %}
                                <div class="grid-product__secondary-image small--hide">
                                  <image-element data-aos="image-fade-in" data-aos-offset="150">
                                    <img src="{{ product_item.images[1] | image_url: width: 1000 }}" 
                                         alt="{{ product_item.images[1].alt | escape }}"
                                         srcset="{{ product_item.images[1] | image_url: width: 360 }} 360w,
                                                 {{ product_item.images[1] | image_url: width: 540 }} 540w,
                                                 {{ product_item.images[1] | image_url: width: 720 }} 720w,
                                                 {{ product_item.images[1] | image_url: width: 1000 }} 1000w"
                                         width="1000" 
                                         loading="lazy" 
                                         sizes="(min-width: 769px) 20vw, 50vw">
                                  </image-element>
                                </div>
                              {% endif %}
                            </div>
                            <div class="grid-product__meta">
                              <div class="grid-product__title">{{ product_item.title }}</div>
                              <div class="grid-product__price">
                                {% if product_item.compare_at_price > product_item.price %}
                                  <span class="grid-product__price--original">{{ product_item.compare_at_price | money }}</span>
                                  <span class="sale-price">{{ product_item.price | money }}</span>
                                {% else %}
                                  {{ product_item.price | money }}
                                {% endif %}
                              </div>
                            </div>
                          </a>
                        </div>
                      </div>
                      {%- assign shown_count = shown_count | plus: 1 -%}
                      {%- assign shown_ids = shown_ids | append: product_item.id | append: ',' -%}
                    {%- endif -%}
                  {%- endunless -%}
                {%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
            
            <div class="grid__item small--hide text-center">
              <a href="{{ target_collection.url }}" class="btn">{{ 'collections.general.all_of_collection' | t }}</a>
            </div>
            <div class="grid__item grid__item--view-all text-center {{ grid_item_width }} medium-up--hide">
              <a href="{{ target_collection.url }}" class="grid-product__see-all">{{ 'collections.general.view_all_products_html' | t: count: target_collection.products_count }}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

{%- else -%}

  {%- liquid
    assign per_row = section.settings.per_row
    assign product_limit = per_row | times: section.settings.rows
    assign collection = collections[section.settings.home_featured_products]
    assign grid_item_width = 'small--one-half medium-up--one-third'
    
    case per_row
      when 1
        assign grid_item_width = ''
      when 2
        assign grid_item_width = 'medium-up--one-half'
      when 3
        assign grid_item_width = 'small--one-half medium-up--one-third'
      when 4
        assign grid_item_width = 'small--one-half medium-up--one-quarter'
      when 5
        assign grid_item_width = 'small--one-half medium-up--one-fifth'
    endcase
  -%}

  {%- if section.settings.divider -%}<div class="section--divider">{%- endif -%}
  
  <div id="CollectionSection-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="featured-collection">
    {%- if section.settings.title != blank -%}
      <div class="page-width">
        <div class="section-header">
          <h2 class="section-header__title">
            {{ section.settings.title }}
            {% if section.settings.view_all and section.settings.rows == 1 %}
              <a href="{{ collections[section.settings.home_featured_products].url }}" class="section-header__link">{{ 'collections.general.all_of_collection' | t }}</a>
            {% endif %}
          </h2>
        </div>
      </div>
    {% endif %}
    
    <div class="page-width page-width--flush-small">
      <div class="grid-overflow-wrapper">
        <div class="grid grid--uniform" data-aos="overflow__animation">
          {% if section.settings.home_featured_products == blank or collections[section.settings.home_featured_products].empty? or collections[section.settings.home_featured_products].products_count == 0 %}
            <div class="grid__item">
              <div class="grid grid--uniform">
                {%- for i in (1..product_limit) -%}
                  <div class="grid__item grid-product {{ grid_item_width }}" data-aos="row-of-{{ per_row }}">
                    <div class="grid-product__content">
                      <a href="{{ product.url | within: collection }}" class="grid-product__link">
                        <div class="grid-product__image-mask">
                          {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                          <div class="image-wrap">{{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}</div>
                        </div>
                        <div class="grid-product__meta">
                          <div class="grid-product__title">{{ 'home_page.onboarding.product_title' | t }}</div>
                          <div class="grid-product__price">$29</div>
                        </div>
                      </a>
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {% else %}
            {%- for product in collections[section.settings.home_featured_products].products limit: product_limit -%}
              {%- render 'product-grid-item', product: product, collection: collection, grid_item_width: grid_item_width, per_row: per_row -%}
            {%- endfor -%}
            
            {% if section.settings.view_all %}
              {% if section.settings.rows > 1 %}
                <div class="grid__item small--hide text-center">
                  <a href="{{ collections[section.settings.home_featured_products].url }}" class="btn">{{ 'collections.general.all_of_collection' | t }}</a>
                </div>
              {% endif %}
              <div class="grid__item grid__item--view-all text-center {{ grid_item_width }} medium-up--hide">
                <a href="{{ collections[section.settings.home_featured_products].url }}" class="grid-product__see-all">{{ 'collections.general.view_all_products_html' | t: count: collection.products_count }}</a>
              </div>
            {% endif %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  
  {%- if section.settings.divider -%}</div>{%- endif -%}

{%- endif -%}

{% schema %}
{
  "name": "Product Recommendations",
  "class": "index-section",
  "settings": [
    {
      "type": "header",
      "content": "Product Page Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You might also like",
      "info": "Heading shown on product pages"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Maximum products to show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "Products per row (desktop)",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 5,
      "info": "Mobile always shows 2 per row"
    },
    {
      "type": "text",
      "id": "mens_broad_collection",
      "label": "Men's parent collection handle",
      "default": "mens-clothes",
      "info": "Collection handle to exclude from recommendations"
    },
    {
      "type": "text",
      "id": "womens_broad_collection",
      "label": "Women's parent collection handle",
      "default": "womens-clothes",
      "info": "Collection handle to exclude from recommendations"
    },
    {
      "type": "header",
      "content": "Homepage Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "collection",
      "id": "home_featured_products",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "per_row",
      "label": "Products per row (desktop)",
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "range",
      "id": "rows",
      "label": "Number of rows",
      "default": 2,
      "min": 1,
      "max": 5,
      "step": 1
    },
    {
      "type": "checkbox",
      "id": "view_all",
      "label": "Show 'View all' button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "Show section divider",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}