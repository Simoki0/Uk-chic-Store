<script>
(function() {
  // Sticky Add to Cart functionality
  const stickyATC = document.getElementById('ukchic-sticky-atc');
  const stickyBtn = document.getElementById('ukchic-sticky-atc-btn');
  const addToCartForm = document.querySelector('[data-product-form]');
  const addToCartBtn = addToCartForm ? addToCartForm.querySelector('[type="submit"]') : null;

  if (stickyATC && addToCartBtn) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          stickyATC.classList.remove('visible');
        } else {
          stickyATC.classList.add('visible');
        }
      });
    }, { threshold: 0 });

    observer.observe(addToCartBtn);

    stickyBtn.addEventListener('click', function() {
      addToCartBtn.click();
    });
  }

  // Image Swatch Active State Handler
  function initImageSwatches() {
    const swatchInputs = document.querySelectorAll('.variant-input--image-swatch input[type="radio"]');

    swatchInputs.forEach(input => {
      input.addEventListener('change', function() {
        // Remove active class from all swatches in this group
        const fieldset = this.closest('fieldset');
        if (fieldset) {
          fieldset.querySelectorAll('.ukchic-image-swatch').forEach(swatch => {
            swatch.classList.remove('is-active');
          });
        }

        // Add active class to selected swatch
        const label = this.nextElementSibling;
        if (label && label.classList.contains('ukchic-image-swatch')) {
          label.classList.add('is-active');
        }

        // Update the color label
        const colorLabel = document.querySelector('[data-variant-color-label]');
        if (colorLabel) {
          colorLabel.textContent = this.value;
        }
      });
    });
  }

  initImageSwatches();

  // Size Button Active State Handler
  function initSizeButtons() {
    const sizeInputs = document.querySelectorAll('.variant-input--size input[type="radio"]');

    sizeInputs.forEach(input => {
      input.addEventListener('change', function() {
        const fieldset = this.closest('fieldset');
        if (fieldset) {
          fieldset.querySelectorAll('.ukchic-size-btn').forEach(btn => {
            btn.classList.remove('is-active');
          });
        }

        const label = this.nextElementSibling;
        if (label && label.classList.contains('ukchic-size-btn')) {
          label.classList.add('is-active');
        }

        // Update size label
        const sizeLabel = document.querySelector('[data-variant-size-label]');
        if (sizeLabel) {
          sizeLabel.textContent = this.value;
        }
      });
    });
  }

  initSizeButtons();

  // Review Count Generator
  function initReviewCount() {
    var el = document.getElementById('ukchic-review-count');
    if (!el) return;
    var path = window.location.pathname;
    var stored = {};
    try { stored = JSON.parse(sessionStorage.getItem('ukReviews') || '{}'); } catch(e) {}
    if (!stored[path]) {
      var count = Math.floor(Math.random() * 1200) + 800;
      var d = count % 10;
      if (d < 5) count += (5 - d);
      else if (d > 5 && d < 7) count += (7 - d);
      else if (d > 7) count = count - d + 15;
      stored[path] = count;
      sessionStorage.setItem('ukReviews', JSON.stringify(stored));
    }
    el.textContent = stored[path].toLocaleString();
  }
  initReviewCount();
})();
</script>