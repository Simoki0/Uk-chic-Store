<div class="cart__item ukchic-cart-item" data-key="{{ product.key }}">
  <div class="cart__item--image ukchic-item-image" data-aos>
    <a href="{{ product.url }}" class="image-wrap" style="display: block; height: 0; padding-bottom: {{ 100 | divided_by: product.image.aspect_ratio }}%;">
      {%- assign img_url = product | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
      <img class="lazyload"
          data-src="{{ img_url }}"
          data-widths="[180, 360, 540]"
          data-aspectratio="{{ product.aspect_ratio }}"
          data-sizes="auto"
          alt="{{ product.product.title | escape }}">
      <noscript>
        <img class="lazyloaded"
          src="{{ product | img_url: '400x' }}"
          alt="{{ product.product.title | escape }}">
      </noscript>
    </a>
  </div>

  <div class="cart__item--details ukchic-item-details">
    <div class="cart__item--name ukchic-item-name">
      <a href="{{ product.url }}" class="cart__product-name ukchic-product-link">
        {{ product.product.title }}
      </a>

      {%- unless product.product.has_only_default_variant -%}
        <div class="cart__variant-meta ukchic-variant-meta">
          {{ product.variant.title }}
        </div>
      {%- endunless -%}
      <div class="{% if product.selling_plan_allocation == empty %}hide {% endif %}ukchic-selling-plan">
        {{ product.selling_plan_allocation.selling_plan.name }}
      </div>

      {%- assign property_size = product.properties | size -%}
      {%- if property_size > 0 -%}
        <div class="ukchic-properties">
        {%- for p in product.properties -%}
          {%- assign first_character_in_key = p.first | truncate: 1, '' -%}
          {%- unless p.last == blank or first_character_in_key == '_' -%}
            <span class="ukchic-property">{{ p.first }}:
            {%- if p.last contains '/uploads/' -%}
              <a href="{{ p.last }}">{{ p.last | split: '/' | last }}</a>
            {%- else -%}
              {{ p.last }}
            {%- endif -%}
            </span>
          {%- endunless -%}
        {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Line item price (shown under name on drawer/mobile) {%- endcomment -%}
      <div class="ukchic-line-price">
        {%- if product.original_price != product.final_price -%}
          <span class="ukchic-line-price-sale">{{ product.final_price | money }}</span>
          <span class="ukchic-line-price-compare">{{ product.original_price | money }}</span>
        {%- else -%}
          <span class="ukchic-line-price-regular">{{ product.original_price | money }}</span>
        {%- endif -%}
      </div>
    </div>

    <div class="cart__item--qty ukchic-item-qty">
      <div class="js-qty__wrapper ukchic-qty-wrapper">
        <label for="cart_updates_{{ product.key }}" class="hidden-label">{{ 'cart.label.quantity' | t }}</label>
        <button type="button"
          class="js-qty__adjust js-qty__adjust--minus ukchic-qty-btn ukchic-qty-minus"
          aria-label="{{ 'cart.general.reduce_quantity' | t }}">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <input type="text"
          id="cart_updates_{{ product.key }}"
          name="updates[]"
          class="js-qty__num ukchic-qty-input"
          value="{{ product.quantity }}"
          min="0"
          pattern="[0-9]*"
          data-id="{{ product.key }}">
        <button type="button"
          class="js-qty__adjust js-qty__adjust--plus ukchic-qty-btn ukchic-qty-plus"
          aria-label="{{ 'cart.general.increase_quantity' | t }}">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </div>
    </div>

    <div class="cart__item--price cart__item-price-col text-right ukchic-item-total">
      {%- if product.original_price != product.final_price -%}
        <span class="visually-hidden">{{ 'products.general.regular_price' | t }}</span>
        <small class="cart__price cart__price--strikethrough ukchic-price-was">{{ product.original_price | money }}</small>
        <span class="visually-hidden">{{ 'products.general.sale_price' | t }}</span>
        <span class="cart__price cart__discount ukchic-price-now">{{ product.final_price | money }}</span>
      {%- else -%}
        <span class="cart__price ukchic-price-regular">{{ product.original_price | money }}</span>
      {%- endif -%}

      {%- if product.line_level_discount_allocations != blank -%}
        {%- for discount_allocation in product.line_level_discount_allocations -%}
          <small class="cart__discount ukchic-line-discount">{{ discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})</small>
        {%- endfor -%}
      {%- endif -%}

      {%- if product.unit_price_measurement -%}
        {%- capture unit_price_base_unit -%}
          <span class="unit-price-base">
            {%- if product.unit_price_measurement -%}
              {%- if product.unit_price_measurement.reference_value != 1 -%}
                {{ product.unit_price_measurement.reference_value }}
              {%- endif -%}
              {{ product.unit_price_measurement.reference_unit }}
            {%- endif -%}
          </span>
        {%- endcapture -%}

        <div class="product__unit-price ukchic-unit-price">{{ product.unit_price | money }}/{{ unit_price_base_unit }}</div>
      {%- endif -%}
    </div>
  </div>
</div>
