<div class="announcement{% if section.settings.announcement_closable %} announcement--closeable announcement--closed{% endif %}" style="background-color: #b00c0c; color: white;">
  {%- if section.settings.announcement_link != blank -%}
    <a href="{{ section.settings.announcement_link }}" class="announcement__link" style="color: white;">
  {%- endif -%}

    <span class="announcement__text{% unless sections.settings.announcement_closable %} announcement__text--open{% endunless %}" data-text="{{ section.settings.announcement_text | strip_html | handle }}">
    <strong> {{ section.settings.announcement_text | strip_html }}  </strong> 
    </span>

  {%- if section.settings.announcement_link != blank -%}
    </a>
  {%- endif -%}

  {%- if section.settings.announcement_closable -%}
    <button type="button" class="text-link announcement__close" style="color: white;">
      <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-close" viewBox="0 0 64 64"><path d="M19 17.61l27.12 27.13m0-27.12L19 44.74" stroke="white"/></svg>
      <span class="icon__fallback-text">{{ 'general.accessibility.close' | t | json }}</span>
    </button>
  {%- endif -%}
</div>