{%- comment -%}
  Product Rating & Trust Badge
  Place this snippet where you want to show the rating and UK badge
{%- endcomment -%}

<div class="ukchic-rating-badge">
  <div class="ukchic-badge-row">
    <div class="ukchic-uk-badge">
      <svg class="ukchic-uk-flag" viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg">
        <rect fill="#00247D" width="60" height="30"/>
        <path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/>
        <path d="M0,0 L60,30 M60,0 L0,30" stroke="#CF142B" stroke-width="2"/>
        <path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/>
        <path d="M30,0 V30 M0,15 H60" stroke="#CF142B" stroke-width="6"/>
      </svg>
      <span class="ukchic-uk-text">UK Owned</span>
    </div>
  </div>

  <div class="ukchic-badge-row ukchic-rating-row">
    <div class="ukchic-stars-wrap">
      {%- for i in (1..5) -%}
        <svg class="ukchic-star" viewBox="0 0 20 20">
          <path d="M10 1l2.5 5.5L18 7.5l-4 4.2 1 6.3-5-3-5 3 1-6.3-4-4.2 5.5-1z"/>
        </svg>
      {%- endfor -%}
    </div>
    <span class="ukchic-review-text">
      <span class="ukchic-review-count" data-review-count>1,247</span> verified reviews
    </span>
  </div>
</div>

<style>
.ukchic-rating-badge {
  display: flex !important;
  flex-direction: column !important;
  gap: 8px !important;
  padding: 0 !important;
  margin: 12px 0 16px !important;
}

.ukchic-badge-row {
  display: flex !important;
  align-items: center !important;
  gap: 8px !important;
}

.ukchic-uk-badge {
  display: inline-flex !important;
  align-items: center !important;
  gap: 8px !important;
  background: transparent !important;
  padding: 0 !important;
}

.ukchic-uk-flag {
  width: 28px !important;
  height: 14px !important;
  border-radius: 2px !important;
  box-shadow: 0 1px 2px rgba(0,0,0,0.1) !important;
  flex-shrink: 0 !important;
}

.ukchic-uk-text {
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: 13px !important;
  font-weight: 600 !important;
  color: #1e3a5f !important;
  letter-spacing: 0.3px !important;
}

.ukchic-rating-row {
  gap: 10px !important;
}

.ukchic-stars-wrap {
  display: flex !important;
  align-items: center !important;
  gap: 2px !important;
}

.ukchic-star {
  width: 16px !important;
  height: 16px !important;
  fill: #1e3a5f !important;
}

.ukchic-review-text {
  font-family: 'Jost', -apple-system, sans-serif !important;
  font-size: 13px !important;
  color: #666 !important;
  line-height: 1 !important;
}

.ukchic-review-count {
  font-weight: 600 !important;
  color: #1e3a5f !important;
}

@media (max-width: 480px) {
  .ukchic-uk-flag {
    width: 24px !important;
    height: 12px !important;
  }

  .ukchic-uk-text {
    font-size: 12px !important;
  }

  .ukchic-star {
    width: 14px !important;
    height: 14px !important;
  }

  .ukchic-review-text {
    font-size: 12px !important;
  }
}
</style>

<script>
(function() {
  function initReviewCount() {
    const countEl = document.querySelector('[data-review-count]');
    if (!countEl) return;

    const path = window.location.pathname;
    let stored = {};

    try {
      stored = JSON.parse(sessionStorage.getItem('ukchicReviews') || '{}');
    } catch(e) {}

    if (!stored[path]) {
      // Generate random count between 800-2000, ending in 5 or 7
      let count = Math.floor(Math.random() * 1200) + 800;
      const lastDigit = count % 10;
      if (lastDigit < 5) count += (5 - lastDigit);
      else if (lastDigit > 5 && lastDigit < 7) count += (7 - lastDigit);
      else if (lastDigit > 7) count = count - lastDigit + 5 + 10;

      stored[path] = count;
      sessionStorage.setItem('ukchicReviews', JSON.stringify(stored));
    }

    countEl.textContent = stored[path].toLocaleString();
  }

  initReviewCount();
  document.addEventListener('page:change', initReviewCount);
})();
</script>
