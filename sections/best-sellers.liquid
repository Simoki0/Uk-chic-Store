{% comment %}Best Selling Products - Homepage Section{% endcomment %}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign per_row = section.settings.products_per_row
  assign max_products = section.settings.products_to_show
  assign grid_item_width = 'small--one-half medium-up--one-third'

  case per_row
    when 2
      assign grid_item_width = 'small--one-half medium-up--one-half'
    when 3
      assign grid_item_width = 'small--one-half medium-up--one-third'
    when 4
      assign grid_item_width = 'small--one-half medium-up--one-quarter'
    when 5
      assign grid_item_width = 'small--one-half medium-up--one-fifth'
    when 6
      assign grid_item_width = 'small--one-half medium-up--one-sixth'
  endcase
-%}

<style>
  .best-sellers-section {
    margin: 60px 0;
  }
  @media (max-width: 768px) {
    .best-sellers-section {
      margin: 40px 0;
    }
  }
</style>

{%- if section.settings.divider -%}<div class="section--divider">{%- endif -%}

<div class="best-sellers-section index-section" id="BestSellersSection-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="best-sellers">
  {%- if section.settings.heading != blank -%}
    <div class="page-width">
      <div class="section-header text-center">
        <h2 class="section-header__title">
          {{ section.settings.heading }}
          {%- if section.settings.show_view_all and collection != blank -%}
            <a href="{{ collection.url }}" class="section-header__link">{{ 'collections.general.all_of_collection' | t }}</a>
          {%- endif -%}
        </h2>
      </div>
    </div>
  {%- endif -%}

  <div class="page-width page-width--flush-small">
    <div class="grid-overflow-wrapper">
      <div class="grid grid--uniform" data-aos="overflow__animation">

        {%- if collection == blank or collection.products_count == 0 -%}
          {%- comment -%}Show placeholder products if no collection selected{%- endcomment -%}
          <div class="grid__item">
            <div class="grid grid--uniform">
              {%- for i in (1..max_products) -%}
                <div class="grid__item grid-product {{ grid_item_width }}" data-aos="row-of-{{ per_row }}">
                  <div class="grid-product__content">
                    <div class="grid-product__link">
                      <div class="grid-product__image-mask">
                        {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                        <div class="image-wrap">{{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}</div>
                      </div>
                      <div class="grid-product__meta">
                        <div class="grid-product__title">{{ 'home_page.onboarding.product_title' | t }}</div>
                        <div class="grid-product__price">$29</div>
                      </div>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>

        {%- else -%}
          {%- comment -%}Show actual best selling products{%- endcomment -%}
          {%- assign best_selling_products = collection.products | sort: 'best-selling' -%}

          {%- for product in best_selling_products limit: max_products -%}
            {%- render 'product-grid-item', product: product, collection: collection, grid_item_width: grid_item_width, per_row: per_row -%}
          {%- endfor -%}

          {%- if section.settings.show_view_all -%}
            <div class="grid__item small--hide text-center">
              <a href="{{ collection.url }}" class="btn">{{ 'collections.general.all_of_collection' | t }}</a>
            </div>
            <div class="grid__item grid__item--view-all text-center {{ grid_item_width }} medium-up--hide">
              <a href="{{ collection.url }}" class="grid-product__see-all">{{ 'collections.general.view_all_products_html' | t: count: collection.products_count }}</a>
            </div>
          {%- endif -%}

        {%- endif -%}

      </div>
    </div>
  </div>
</div>

{%- if section.settings.divider -%}</div>{%- endif -%}

{% schema %}
{
  "name": "Best Sellers",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select which collection to show best selling products from"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Maximum products to show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "Products per row (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "info": "Mobile always shows 2 per row"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "Show section divider",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Best Sellers",
      "category": "Collection"
    }
  ]
}
{% endschema %}
